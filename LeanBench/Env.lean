import Lean
import LeanBench.Core

/-!
# `LeanBench.Env` — registry plumbing

Two registries, kept in lockstep by a single `register` API:

1. **Compile-time** (`benchSpecExt`): a `SimplePersistentEnvExtension`
   storing `BenchmarkSpec` records. Used by anything that needs to
   inspect the benchmark catalogue at elaboration / build time.
2. **Runtime** (`runtimeRegistry`): a plain `IO.Ref` of
   `Std.HashMap Name RuntimeEntry`. Populated at module init by code
   generated by `setup_benchmark`. The child looks up `runner` for
   dispatch; the parent looks up `complexity` (to compute ratios) and
   `spec` (to drive the ladder).

The dual registry is unavoidable — env extensions are an
elaboration-time concept and the runtime needs callable closures —
but the macro emits exactly one `LeanBench.register` call, so the
duality stays out of user code.
-/

open Lean

namespace LeanBench

/-! ## Compile-time registry -/

initialize benchSpecExt : SimplePersistentEnvExtension BenchmarkSpec (Array BenchmarkSpec) ←
  registerSimplePersistentEnvExtension {
    name := `LeanBench.benchSpecExt
    addImportedFn := fun ass => ass.foldl (· ++ ·) #[]
    addEntryFn    := fun s e => s.push e
  }

/-- Insert a `BenchmarkSpec` into the persistent env extension. -/
def addSpec (env : Environment) (spec : BenchmarkSpec) : Environment :=
  benchSpecExt.addEntry env spec

/-- Look up the spec for `name` (compile-time / parent-side). -/
def findSpec (env : Environment) (name : Name) : Option BenchmarkSpec :=
  (benchSpecExt.getState env).find? (·.name == name)

/-- All registered specs in this environment. -/
def allSpecs (env : Environment) : Array BenchmarkSpec :=
  benchSpecExt.getState env

/-! ## Runtime registry -/

/-- One entry: the spec plus the two callable closures for the
    function and its complexity model. -/
structure RuntimeEntry where
  spec       : BenchmarkSpec
  runner     : Nat → IO (Option UInt64)
  complexity : Nat → Nat
  deriving Inhabited

/-- The runtime registry. Populated at module init. -/
initialize runtimeRegistry : IO.Ref (Std.HashMap Name RuntimeEntry) ←
  IO.mkRef {}

/-- Look up an entry by name. -/
def findRuntimeEntry (name : Name) : IO (Option RuntimeEntry) := do
  return (← runtimeRegistry.get).get? name

/-- All entries registered in this binary. -/
def allRuntimeEntries : IO (Array RuntimeEntry) := do
  return (← runtimeRegistry.get).valuesArray

/-! ## The single registration API the macro emits -/

/--
Atomic registration: insert one `RuntimeEntry` into the runtime
registry. Called at most once per benchmark, by code emitted from the
`setup_benchmark` macro.

The persistent env extension is updated separately by the macro at
elaboration time via `modifyEnv` — that's the only place the
dual-registry split is exposed, and macro authors and end users do
not call the two halves directly.
-/
def register
    (spec : BenchmarkSpec)
    (runner : Nat → IO (Option UInt64))
    (complexity : Nat → Nat) :
    IO Unit :=
  runtimeRegistry.modify (·.insert spec.name { spec, runner, complexity })

end LeanBench
