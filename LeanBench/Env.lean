import Lean
import LeanBench.Core

/-!
# `LeanBench.Env` ÔÇö registry plumbing

Two registries, kept in lockstep by a single `register` API:

1. **Compile-time** (`benchSpecExt`): a `SimplePersistentEnvExtension`
   storing `BenchmarkSpec` records. Used by anything that needs to
   inspect the benchmark catalogue at elaboration / build time.
2. **Runtime** (`runtimeRegistry`): a plain `IO.Ref` of
   `Std.HashMap Name RuntimeEntry`. Populated at module init by code
   generated by `setup_benchmark`. The child looks up `runner` for
   dispatch; the parent looks up `complexity` (to compute ratios) and
   `spec` (to drive the ladder).

The dual registry is unavoidable ÔÇö env extensions are an
elaboration-time concept and the runtime needs callable closures ÔÇö
but the macro emits exactly one `LeanBench.register` call, so the
duality stays out of user code.
-/

open Lean

namespace LeanBench

/-! ## Black-box (defeat dead-code elimination)

The Lean compiler will happily lift `f param` out of a tight loop when
`f` is pure and `param` is loop-invariant. That collapses our
N-iteration timing batch into one call's worth of work. To stop it,
we route every per-iteration result through a `@[noinline]` consumer
that the compiler must treat as opaque: the call site can't be
elided, so the argument computation can't be elided either.

The body itself is a single `IO.Ref.modify`; the ref is private and
its accumulated value is never read, so this is essentially free at
runtime (a few ns per call) but kills LICM / CSE on the hot loop. -/

private initialize blackBoxRef : IO.Ref UInt64 ÔåÉ IO.mkRef 0

/-- Opaque consumer used by generated benchmark loops. `@[noinline]`
forces the compiler to emit a real call, which forces the argument
to be computed. The accumulator is never observed externally. -/
@[noinline] def blackBox (a : UInt64) : IO Unit :=
  blackBoxRef.modify (┬À ^^^ a)

/-! ## Compile-time registry -/

initialize benchSpecExt : SimplePersistentEnvExtension BenchmarkSpec (Array BenchmarkSpec) ÔåÉ
  registerSimplePersistentEnvExtension {
    name := `LeanBench.benchSpecExt
    addImportedFn := fun ass => ass.foldl (┬À ++ ┬À) #[]
    addEntryFn    := fun s e => s.push e
  }

/-- Insert a `BenchmarkSpec` into the persistent env extension. -/
def addSpec (env : Environment) (spec : BenchmarkSpec) : Environment :=
  benchSpecExt.addEntry env spec

/-- Look up the spec for `name` (compile-time / parent-side). -/
def findSpec (env : Environment) (name : Name) : Option BenchmarkSpec :=
  (benchSpecExt.getState env).find? (┬À.name == name)

/-- All registered specs in this environment. -/
def allSpecs (env : Environment) : Array BenchmarkSpec :=
  benchSpecExt.getState env

/-! ## Runtime registry -/

/-- One entry: the spec plus the two callable closures for the
    function and its complexity model. -/
structure RuntimeEntry where
  spec       : BenchmarkSpec
  /-- Two-stage runner:

      1. Apply to `param`: this runs any per-param setup (the `prep`
         function from `setup_benchmark ÔÇª with prep := ÔÇª`, when
         present) and returns a closure that holds the prepared state.
      2. Apply that closure to `count`: this runs the function under
         test `count` times, hashing each result, and returns
         `(loopNanos, lastHash)` where `loopNanos` is the wall time
         spent *only* inside the inner loop.

      Per-param setup therefore runs once per child-process spawn ÔÇö
      not once per autotuner probe ÔÇö and the inner loop's IO closure
      captures the prepared value, so the function-under-test can be
      inlined into the loop body with no per-iteration indirection.
      The `lastHash` is `some _` iff the function's return type has
      `Hashable`; the runner forces the prep result before the timer
      starts so prep cost does not leak into the reported nanos. -/
  runner     : (param : Nat) ÔåÆ IO (Nat ÔåÆ IO (Nat ├ù Option UInt64))
  complexity : Nat ÔåÆ Nat
  deriving Inhabited

/-- The runtime registry. Populated at module init. -/
initialize runtimeRegistry : IO.Ref (Std.HashMap Name RuntimeEntry) ÔåÉ
  IO.mkRef {}

/-- Look up an entry by name. -/
def findRuntimeEntry (name : Name) : IO (Option RuntimeEntry) := do
  return (ÔåÉ runtimeRegistry.get).get? name

/-- All entries registered in this binary. -/
def allRuntimeEntries : IO (Array RuntimeEntry) := do
  return (ÔåÉ runtimeRegistry.get).valuesArray

/-! ## The single registration API the macro emits -/

/--
Atomic registration: insert one `RuntimeEntry` into the runtime
registry. Called at most once per benchmark, by code emitted from the
`setup_benchmark` macro.

The persistent env extension is updated separately by the macro at
elaboration time via `modifyEnv` ÔÇö that's the only place the
dual-registry split is exposed, and macro authors and end users do
not call the two halves directly.
-/
def register
    (spec : BenchmarkSpec)
    (runner : (param : Nat) ÔåÆ IO (Nat ÔåÆ IO (Nat ├ù Option UInt64)))
    (complexity : Nat ÔåÆ Nat) :
    IO Unit :=
  runtimeRegistry.modify (┬À.insert spec.name { spec, runner, complexity })

end LeanBench
